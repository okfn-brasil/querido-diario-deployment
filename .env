# Variáveis de ambiente para o Querido Diário
# ============================================
# Copie este arquivo, preencha os valores e use no deploy.
# Produção: cp .env .env.production && edite .env.production
#
# Variáveis sem valor padrão nos compose files DEVEM ser definidas aqui.

# =============================================================================
# DOMÍNIO
# =============================================================================

DOMAIN=queridodiario.ok.org.br

# =============================================================================
# IMAGENS DOCKER
# =============================================================================

APACHE_TIKA_IMAGE_TAG=
API_IMAGE_TAG=
BACKEND_IMAGE_TAG=
DATA_PROCESSING_IMAGE_TAG=

# =============================================================================
# RECURSOS DE DEPLOYMENT (memória/replicas)
# =============================================================================

APACHE_TIKA_MEMORY_LIMIT=2500M
APACHE_TIKA_MEMORY_RESERVATION=1200M

API_MEMORY_LIMIT=1024M
API_MEMORY_RESERVATION=512M
API_REPLICAS=1

BACKEND_MEMORY_LIMIT=512M
BACKEND_MEMORY_RESERVATION=256M
BACKEND_REPLICAS=1

CELERY_BEAT_MEMORY_LIMIT=256M
CELERY_BEAT_MEMORY_RESERVATION=128M

CELERY_WORKER_MEMORY_LIMIT=1G
CELERY_WORKER_MEMORY_RESERVATION=512M
CELERY_WORKER_REPLICAS=1

DATA_PROCESSING_MEMORY_LIMIT=2048M
DATA_PROCESSING_MEMORY_RESERVATION=512M

# =============================================================================
# TRAEFIK
# =============================================================================

ACME_EMAIL=
TRAEFIK_DASHBOARD_DOMAIN=traefik.ok.org.br
# Gere com: htpasswd -nB usuario | sed 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_USERS=
TRAEFIK_LOG_LEVEL=ERROR
CERT_RESOLVER=leresolver

# Frontend upstream (Netlify ou outro)
FRONTEND_UPSTREAM_URL=https://querido-diario-plataforma.netlify.app

# CORS (lista separada por vírgula, ou * para todos)
CORS_ALLOW_ORIGIN_LIST=*

# =============================================================================
# SEGURANÇA
# =============================================================================

QD_BACKEND_SECRET_KEY=

# =============================================================================
# OPENSEARCH
# =============================================================================

QUERIDO_DIARIO_OPENSEARCH_HOST=
QUERIDO_DIARIO_OPENSEARCH_INDEX=queridodiario
QUERIDO_DIARIO_OPENSEARCH_USER=
QUERIDO_DIARIO_OPENSEARCH_PASSWORD=

# =============================================================================
# BANCO DE DADOS - Querido Diário (API + Data Processing)
# =============================================================================

QD_DATA_DB_NAME=queridodiariodb
QD_DATA_DB_HOST=
QD_DATA_DB_PORT=5432
QD_DATA_DB_USER=
QD_DATA_DB_PASSWORD=

# =============================================================================
# BANCO DE DADOS - Backend + Celery
# =============================================================================

QD_BACKEND_DB_NAME=queridodiariobackend
QD_BACKEND_DB_HOST=
QD_BACKEND_DB_PORT=5432
QD_BACKEND_DB_USER=
QD_BACKEND_DB_PASSWORD=

# =============================================================================
# BANCO DE DADOS - Empresas/Companies (API)
# =============================================================================

POSTGRES_COMPANIES_DB=qd_receita
POSTGRES_COMPANIES_HOST=
POSTGRES_COMPANIES_PORT=5432
POSTGRES_COMPANIES_USER=
POSTGRES_COMPANIES_PASSWORD=

# =============================================================================
# ARMAZENAMENTO (S3 ou compatível)
# =============================================================================

# Endpoint para a API e frontend (URL pública dos arquivos)
QUERIDO_DIARIO_FILES_ENDPOINT=
REPLACE_FILE_URL_BASE=False

# Data Processing (acesso direto ao bucket)
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_ACCESS_SECRET=
STORAGE_BUCKET=

# =============================================================================
# EMAIL
# =============================================================================

MAILJET_API_KEY=
MAILJET_SECRET_KEY=
DEFAULT_FROM_EMAIL=
SERVER_EMAIL=
QUOTATION_TO_EMAIL=
QUERIDO_DIARIO_SUGGESTION_RECIPIENT_EMAIL=

# =============================================================================
# CORS / BACKEND
# =============================================================================

# Regex para origens adicionais permitidas (ex: PRs do Netlify)
QD_BACKEND_ALLOWED_ORIGIN_REGEXES=

# =============================================================================
# DATA PROCESSING
# =============================================================================

EXECUTION_MODE=UNPROCESSED
# DATA_PROCESSING_DATABASE_RESTORE_FILE=

# Secrets para o GitHub Actions — Deploy Revoada
# ================================================
# Copie este arquivo para scripts/secrets.txt, preencha os valores reais
# e NUNCA versione o secrets.txt.
#
# Formato: NOME_DO_SECRET=valor
# Linhas começando com # são ignoradas. Linhas em branco também.
#
# Regras importantes:
#   - NÃO use aspas: KEY="valor" envia as aspas como parte do segredo
#   - NÃO use espaços em torno do =: KEY = valor quebra o parsing
#   - NÃO use comentários inline: KEY=valor # obs → "# obs" vira parte do valor
#   - Caracteres especiais (@ ! $ / - _ + = ( )) são seguros sem aspas
#
# Para valores multi-linha (ex: WireGuard config, kubeconfig), use o prefixo file:
# apontando para o arquivo no seu sistema local:
#   WIREGUARD_CONFIG=file:/home/user/revoada.conf
#   KUBECONFIG_REVOADA=file:/home/user/.kube/revoada.yaml
#
# Para usar: bash scripts/load-secrets.sh

# ── VPN e acesso ao cluster ───────────────────────────────────────────────────
# Conteúdo completo do arquivo .conf do WireGuard (multi-linha: use o arquivo diretamente)
WIREGUARD_CONFIG=

# Conteúdo do kubeconfig do Revoada (multi-linha: use o arquivo diretamente)
KUBECONFIG_REVOADA=

# Conteúdo do k8s/overlays/production-local/kustomization.yaml
KUSTOMIZATION_PROD_LOCAL=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USERNAME=
POSTGRES_PASSWORD=

# ── Backup Postgres → Ceph Object Store ──────────────────────────────────────
POSTGRES_BACKUP_ACCESS_KEY=
POSTGRES_BACKUP_SECRET_KEY=

# ── Aplicação (Django / API) ──────────────────────────────────────────────────
QD_BACKEND_SECRET_KEY=
QD_BACKEND_DB_URL=

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_HOST=
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=

# ── Storage S3 (AWS) ──────────────────────────────────────────────────────────
STORAGE_ACCESS_KEY=
STORAGE_ACCESS_SECRET=
STORAGE_BUCKET=

# ── Mailjet ───────────────────────────────────────────────────────────────────
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
SUGGESTION_RECIPIENT_EMAIL=
